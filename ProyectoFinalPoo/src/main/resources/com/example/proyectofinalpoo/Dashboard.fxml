<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #fcf9f2;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashboardController">
    <children>
        <VBox alignment="CENTER" layoutX="50.0" layoutY="50.0" spacing="20.0" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="50.0">
            <children>
                <Label text="✂ Panel de Control Principal" textFill="#1a1a1a">
                    <font>
                        <Font name="Georgia Bold" size="32.0" />
                    </font>
                </Label>
                <Label text="Bienvenido al sistema de administración de Belleza Elegante" textFill="#8c7653">
                    <font>
                        <Font name="Georgia Italic" size="16.0" />
                    </font>
                </Label>

                <Label fx:id="lblNombreUsuario" text="Usuario: Invitado" textFill="#bfa36f">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
